{
  "name": "ZARELON-web",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:api\" \"npm:dev:web\"",
    "dev:public": "concurrently -k \"npm:dev\" \"npm:tunnel\"",
    "dev:web": "vite",
    "dev:api": "vercel dev --yes --listen 3000",
    "tunnel": "npx localtunnel --port 3000 --print-requests",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "tsc --noEmit"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.11",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.3.0",
    "@types/pdfkit": "^0.17.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.24",
    "concurrently": "^9.2.1",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.6",
    "supabase": "^2.76.14",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.3",
    "vercel": "^50.1.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.97.0",
    "@tanstack/react-query": "^5.90.21",
    "clsx": "^2.1.1",
    "gsap": "^3.14.2",
    "lucide-react": "^0.575.0",
    "pdfkit": "^0.17.2",
    "razorpay": "^2.9.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.0",
    "resend": "^6.9.2",
    "zod": "^4.3.6"
  }
}
